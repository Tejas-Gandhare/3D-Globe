        "# Import required libraries\n",
        "import pandas as pd\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.svm import SVC"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Step 1: Read Excel file (dataset)\n",
        "data = pd.read_excel(\"creditcard_data.xlsx\")\n",
        "# Step 2: Display first few rows\n",
        "print(\"Sample Data:\\n\", data.head())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 0
        },
        "id": "JHPxJ-FDFH9w",
        "outputId": "e623bb88-0b8b-460b-937e-cd3c794a32ac"
      },
      "execution_count": 2,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Sample Data:\n",
            "    TransactionID  Amount   Time  Label\n",
            "0           1001  380.79  50015      0\n",
            "1           1002  951.21  54268      1\n",
            "2           1003  734.67  18141      0\n",
            "3           1004  602.67  80356      0\n",
            "4           1005  164.46  71910      0\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Step 3: Features (X) and Target (y)\n",
        "X = data[['Amount', 'Time']] # You can add more columns if available\n",
        "y = data['Label']\n",
        "# Step 4: Split data into training and testing\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)\n",
        "# Step 5: Feature scaling (important for SVM)\n",
        "scaler = StandardScaler()\n",
        "X_train_scaled = scaler.fit_transform(X_train)\n",
        "X_test_scaled = scaler.transform(X_test)"
      ],
      "metadata": {
        "id": "rgqjgMv7FMlD"
      },
      "execution_count": 3,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Step 6: Train the SVM model\n",
        "svm_model = SVC(kernel='linear', random_state=42)\n",
        "svm_model.fit(X_train_scaled, y_train)\n",
        "# Step 7: Make predictions\n",
        "y_pred = svm_model.predict(X_test_scaled)"
      ],
      "metadata": {
        "id": "Ys27sanaFRXE"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Step 8: Create result DataFrame\n",
        "results = X_test.copy()\n",
        "results['Prediction'] = ['Fraudulent' if p == 1 else 'Genuine' for p in y_pred]\n",
        "results['TransactionID'] = data.loc[X_test.index, 'TransactionID'].values\n",
        "results = results[['TransactionID', 'Amount', 'Prediction']]\n",
        "# Step 9: Print output table\n",
        "print(\"\\n--- Output (Result) ---\")\n",
        "print(results.head(10))"
      ],
